# RunPod API key — generate at https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Serverless endpoint ID — copy from your endpoint's detail page
RUNPOD_ENDPOINT_ID=xxxxxxxxxxxxxxx

# Optional: override the RunPod API base if you've set up regional routing
# RUNPOD_API_BASE=https://api.runpod.ai/v2
